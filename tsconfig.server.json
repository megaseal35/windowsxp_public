{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-server",
    "rootDir": ".",
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "jsx": "preserve",
    "noEmit": false,
    "sourceMap": true,
    "declaration": false
  },
  "include": ["server/**/*", "shared/**/*"],
  "exclude": ["server/scripts/**/*", "node_modules", "dist", "dist-server"]
}
