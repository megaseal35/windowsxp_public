# Copy to server/.env and adjust as needed.
DB_HOST=localhost
DB_PORT=3306
DB_USER=blog
DB_PASSWORD=localdev
DB_NAME=blog
PORT=3001

# Where uploaded files are stored.
# Dev default (when unset): ./uploads relative to the project.
# On Hostinger, set this to a path OUTSIDE the deployment dir, e.g.:
#   UPLOAD_DIR=/home/<user>/data/uploads
# That way redeploys don't wipe user uploads.
# UPLOAD_DIR=

# Admin user lives in the `users` table now — seed it manually:
#   1. hash=$(npx tsx server/scripts/hashPassword.ts mySecretPassword)
#   2. mysql -u root blog -e \
#        "INSERT INTO users (username, password_hash, is_admin) \
#         VALUES ('yay', '<paste-hash>', TRUE);"

# Long random string used to sign the session cookie.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=
